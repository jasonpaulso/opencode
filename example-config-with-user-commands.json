{
  "$schema": "https://opencode.ai/config.json",
  "commands": {
    "my_custom_command": {
      "description": "My custom command",
      "keybind": "<leader>x",
      "trigger": ["custom", "mycmd"]
    },
    "quick_note": {
      "description": "Quick note taking",
      "keybind": "ctrl+shift+n",
      "trigger": ["note", "quick"]
    },
    "toggle_feature": {
      "description": "Toggle experimental feature",
      "trigger": ["toggle", "feature"]
    }
  },
  "keybinds": {
    "app_help": "<leader>?",
    "session_new": "ctrl+n"
  },
  "mcp": {
    "weather": {
      "type": "local",
      "command": ["opencode", "x", "@h1deya/mcp-server-weather"]
    }
  }
}